#!/usr/bin/env bash
#
# Pre-push hook: runs tests with coverage checks before allowing push.
# Mirrors CI pipeline (go test + vitest) to catch issues locally.
# When a release tag (vX.Y.Z) is pushed, it additionally refuses to release
# with stale minor/patch dependencies (see scripts/update-deps.sh).
#
# To bypass in emergencies: git push --no-verify
#

set -euo pipefail

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Coverage thresholds (percentage)
GO_COVERAGE_THRESHOLD=85
FE_COVERAGE_THRESHOLD=85

REPO_ROOT="$(git rev-parse --show-toplevel)"

info()  { echo -e "${CYAN}▸${NC} $*"; }
pass()  { echo -e "${GREEN}✓${NC} $*"; }
fail()  { echo -e "${RED}✗${NC} $*"; }
warn()  { echo -e "${YELLOW}!${NC} $*"; }

errors=0

# ─── Release-tag dependency freshness ──────────────────────────────
# When a version tag (vX.Y.Z) is among the refs being pushed, refuse the push
# if minor/patch dependency updates are available -- the ones
# scripts/update-deps.sh would pull in -- so a release never ships one weekly
# Dependabot run behind. Major upgrades are intentionally excluded; they stay
# as reviewable Dependabot PRs. Reads the pre-push ref list from stdin.
# Only fires on release tags, so ordinary pushes are unaffected.
# Bypass with: git push --no-verify
pushing_release_tag=false
while read -r _lref _lsha rref _rsha; do
    case "${rref:-}" in
        refs/tags/v[0-9]*) pushing_release_tag=true ;;
    esac
done

if [ "$pushing_release_tag" = true ]; then
    info "Release tag detected — checking dependencies are current..."
    dep_stale=0

    if command -v go >/dev/null 2>&1; then
        GO_UPDATES=$(go list -m -u -f '{{if and .Update (not .Indirect)}}  {{.Path}} {{.Version}} -> {{.Update.Version}}{{end}}' all 2>/dev/null | grep -v '^[[:space:]]*$' || true)
        if [ -n "$GO_UPDATES" ]; then
            fail "Go dependency updates available (minor/patch):"
            echo "$GO_UPDATES"
            dep_stale=1
        fi
    fi

    if command -v npm >/dev/null 2>&1 && command -v node >/dev/null 2>&1; then
        NPM_UPDATES=$( (cd "$REPO_ROOT/web" && npm outdated --json 2>/dev/null || true) | node -e 'let o={};try{o=JSON.parse(require("fs").readFileSync(0,"utf8")||"{}")}catch(e){}; for(const [k,v] of Object.entries(o)){ if(v&&v.current&&v.wanted&&v.current!==v.wanted) console.log("  "+k+" "+v.current+" -> "+v.wanted) }' 2>/dev/null || true)
        if [ -n "$NPM_UPDATES" ]; then
            fail "Frontend dependency updates available (within range):"
            echo "$NPM_UPDATES"
            dep_stale=1
        fi
    fi

    if [ "$dep_stale" -ne 0 ]; then
        echo ""
        echo -e "${RED}${BOLD}Release blocked:${NC} dependencies are behind their latest minor/patch."
        echo -e "Run ${YELLOW}scripts/update-deps.sh${NC}, commit the result, move the tag to the new commit, then push again."
        echo -e "Majors stay as Dependabot PRs. Override with ${YELLOW}git push --no-verify${NC}."
        exit 1
    fi
    pass "Dependencies current."
fi

# ─── Go tests with race detection + coverage ───────────────────────
info "Running Go tests with coverage..."

# Exclude cmd/ packages — they're main() entry points with no tests, and
# compiling them with -race can trigger toolchain version mismatch errors
# when the system Go differs from go.mod's toolchain directive.
# Also exclude vendored Go files inside web/node_modules (e.g. the
# flatted package ships a Go source file that go list picks up but
# isn't part of our module's testable surface).
GO_PACKAGES=$(go list ./... | grep -v '/cmd/' | grep -v 'node_modules')

GO_COVER_FILE=$(mktemp)
if go test -count=1 -race -coverprofile="$GO_COVER_FILE" $GO_PACKAGES 2>&1 | tail -20; then
    pass "Go tests passed"

    # Parse overall coverage
    GO_COVERAGE=$(go tool cover -func="$GO_COVER_FILE" | grep "^total:" | awk '{print $NF}' | sed 's/%//')

    if [ -n "$GO_COVERAGE" ]; then
        # Compare as integers (bash doesn't do float comparison natively)
        GO_COV_INT=$(echo "$GO_COVERAGE" | cut -d. -f1)
        if [ "$GO_COV_INT" -ge "$GO_COVERAGE_THRESHOLD" ]; then
            pass "Go coverage: ${GO_COVERAGE}% (threshold: ${GO_COVERAGE_THRESHOLD}%)"
        else
            fail "Go coverage: ${GO_COVERAGE}% — below ${GO_COVERAGE_THRESHOLD}% threshold"
            errors=$((errors + 1))
        fi
    else
        warn "Could not parse Go coverage"
    fi
else
    fail "Go tests failed"
    errors=$((errors + 1))
fi
rm -f "$GO_COVER_FILE"

# ─── golangci-lint ────────────────────────────────────────────────
info "Running golangci-lint..."
if command -v golangci-lint >/dev/null 2>&1; then
    if golangci-lint run ./... >/dev/null 2>&1; then
        pass "golangci-lint clean"
    else
        # Re-run with output so the operator sees what failed.
        golangci-lint run ./... 2>&1 | tail -30
        fail "golangci-lint reported issues"
        errors=$((errors + 1))
    fi
else
    warn "golangci-lint not installed; skipping (install with: go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest)"
fi

# ─── govulncheck ──────────────────────────────────────────────────
info "Running govulncheck..."
GOBIN_PATH="$(go env GOPATH)/bin"
if [ -x "$GOBIN_PATH/govulncheck" ] || command -v govulncheck >/dev/null 2>&1; then
    PATH="$GOBIN_PATH:$PATH" govulncheck ./... > /tmp/govulncheck.out 2>&1
    GOVULN_EXIT=$?
    if [ "$GOVULN_EXIT" -eq 0 ]; then
        pass "govulncheck found no vulnerabilities"
    else
        cat /tmp/govulncheck.out
        fail "govulncheck reported vulnerabilities"
        errors=$((errors + 1))
    fi
    rm -f /tmp/govulncheck.out
else
    warn "govulncheck not installed; skipping (install with: go install golang.org/x/vuln/cmd/govulncheck@latest)"
fi

# ─── Frontend tests with coverage ─────────────────────────────────
info "Running frontend tests with coverage..."

FE_OUTPUT=$(cd "$REPO_ROOT/web" && npx vitest run --coverage 2>&1)
FE_EXIT=$?

if [ $FE_EXIT -eq 0 ]; then
    pass "Frontend tests passed"

    # Parse overall statement coverage from the "All files" line
    FE_COVERAGE=$(echo "$FE_OUTPUT" | grep "All files" | awk -F'|' '{gsub(/ /,"",$2); print $2}')

    if [ -n "$FE_COVERAGE" ]; then
        FE_COV_INT=$(echo "$FE_COVERAGE" | cut -d. -f1)
        if [ "$FE_COV_INT" -ge "$FE_COVERAGE_THRESHOLD" ]; then
            pass "Frontend coverage: ${FE_COVERAGE}% (threshold: ${FE_COVERAGE_THRESHOLD}%)"
        else
            fail "Frontend coverage: ${FE_COVERAGE}% — below ${FE_COVERAGE_THRESHOLD}% threshold"
            errors=$((errors + 1))
        fi
    else
        warn "Could not parse frontend coverage"
    fi
else
    echo "$FE_OUTPUT" | tail -20
    fail "Frontend tests failed"
    errors=$((errors + 1))
fi

# ─── Summary ───────────────────────────────────────────────────────
echo ""
if [ "$errors" -gt 0 ]; then
    echo -e "${RED}${BOLD}Push blocked:${NC} $errors check(s) failed."
    echo -e "Fix issues above or use ${YELLOW}git push --no-verify${NC} to bypass."
    exit 1
else
    echo -e "${GREEN}${BOLD}All checks passed.${NC} Pushing..."
    exit 0
fi
